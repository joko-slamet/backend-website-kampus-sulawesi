generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Article {
  id            String   @id
  image         String?
  category      String
  categoryColor String
  date          String
  readTime      String
  title         String
  excerpt       String
  tag           String?
  tagColor      String?
  titleEn       String
  excerptEn     String
  content       String?
  contentEn     String?
  views         Int      @default(0)
  published     Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model SchedulerConfig {
  id        String   @id @default("default")
  enabled   Boolean  @default(true)
  times     String[]
  updatedAt DateTime @updatedAt
}

model WhatsappClickLog {
  id        String   @id @default(cuid())
  page      String   @default("/")
  createdAt DateTime @default(now())
}

model Program {
  id            String   @id
  icon          String
  badge         String
  badgeColor    String
  name          String
  degree        String
  accreditation String
  description   String
  highlights    String[]
  color         String
  bgGradient    String
  alumni        String
  status        String   @default("aktif")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
