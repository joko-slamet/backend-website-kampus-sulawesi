{
  "name": "backend-website-kampus-sulawesi",
  "version": "1.0.0",
  "description": "REST API backend for STIMIK Nusantara website",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate && tsc && prisma migrate deploy && npx tsx prisma/seed.ts",
    "start": "node dist/index.js",
    "db:migrate": "prisma migrate dev",
